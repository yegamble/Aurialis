{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://aurialis.yosefgamble.com",
          "http://localhost:3000"
        ],
        "methods": ["PUT"],
        "headers": [
          "content-type",
          "content-length",
          "x-amz-content-sha256",
          "x-amz-date"
        ]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
