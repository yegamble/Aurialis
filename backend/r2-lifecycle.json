{
  "rules": [
    {
      "id": "expire-uploads-48h",
      "enabled": true,
      "conditions": { "prefix": "" },
      "deleteObjectsTransition": {
        "condition": { "type": "Age", "maxAge": 172800 }
      }
    },
    {
      "id": "abort-incomplete-multipart-1d",
      "enabled": true,
      "conditions": { "prefix": "" },
      "abortMultipartUploadsTransition": {
        "condition": { "type": "Age", "maxAge": 86400 }
      }
    }
  ]
}
