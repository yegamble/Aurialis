            {
              "name": "TS-003: Poll Status",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/jobs/{{deepJobId}}/status",
                  "host": ["{{baseUrl}}"],
                  "path": ["jobs", "{{deepJobId}}", "status"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('TS-003 poll: status is 200', () => pm.response.to.have.status(200));",
                      "const body = pm.response.json();",
                      "if (body.status === 'done') {",
                      "  pm.environment.unset('pollCount');",
                      "  pm.execution.setNextRequest('TS-003: Get Result');",
                      "} else if (body.status === 'error') {",
                      "  pm.test('TS-003: job did not error', () => { throw new Error('Job errored: ' + body.error); });",
                      "  pm.execution.setNextRequest(null);",
                      "} else {",
                      "  const count = parseInt(pm.environment.get('pollCount') || '0') + 1;",
                      "  pm.environment.set('pollCount', String(count));",
                      "  const max = parseInt(pm.environment.get('pollMaxIterations') || '45');",
                      "  if (count >= max) {",
                      "    pm.test('TS-003: poll did not time out', () => { throw new Error('Poll timeout after ' + count + ' iterations'); });",
                      "    pm.execution.setNextRequest(null);",
                      "  } else {",
                      "    pm.execution.setNextRequest('TS-003: Poll Status');",
                      "  }",
                      "}"
                    ]
                  }
                }
              ]
            },
