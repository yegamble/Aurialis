            {
              "name": "TS-009: Filename Header Injection Defense",
              "description": "Upload with a filename containing CRLF + injected header chars. Backend must NOT echo any X-Injected response header.",
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "file",
                      "type": "file",
                      "src": "fixtures/normal_3s.wav",
                      "fileName": "evil\\r\\nX-Injected: yes\\r\\n.wav"
                    },
                    {"key": "model", "value": "htdemucs", "type": "text"}
                  ]
                },
                "url": {"raw": "{{baseUrl}}/separate", "host": ["{{baseUrl}}"], "path": ["separate"]}
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('TS-009: response is < 500 (no server crash on bad filename)', () => pm.expect(pm.response.code).to.be.below(500));",
                      "pm.test('TS-009: X-Injected header is NOT present in response', () => {",
                      "  const injected = pm.response.headers.get('X-Injected');",
                      "  pm.expect(injected, 'response leaked injected header').to.be.null;",
                      "});",
                      "pm.test('TS-009: response body does not echo raw CRLF from filename', () => {",
                      "  const text = pm.response.text() || '';",
                      "  pm.expect(text).to.not.match(/X-Injected:\\s*yes/i);",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "TS-011: CORS Preflight (Disallowed Origin)",
              "request": {
                "method": "OPTIONS",
                "header": [
                  {"key": "Origin", "value": "https://attacker.example"},
                  {"key": "Access-Control-Request-Method", "value": "POST"},
                  {"key": "Access-Control-Request-Headers", "value": "content-type"}
                ],
                "url": {"raw": "{{baseUrl}}/separate", "host": ["{{baseUrl}}"], "path": ["separate"]}
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('TS-011: disallowed origin gets no allow-origin header', () => {",
                      "  const allow = pm.response.headers.get('Access-Control-Allow-Origin');",
