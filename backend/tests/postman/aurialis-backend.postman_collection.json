{
  "info": {
    "name": "Aurialis Backend E2E",
    "_postman_id": "aurialis-backend-e2e",
    "description": "End-to-end Postman/Newman suite for the Aurialis FastAPI backend. PR Suite is the merge-blocking subset; Long Audio (Nightly) runs on cron; Production Smoke runs read-only against the live container post-deploy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "PR Suite",
      "description": "Merge-blocking. Runs in PR CI against docker-compose backend on localhost:8000. Excludes long-audio (deferred to nightly).",
      "item": [
        {
          "name": "Health",
          "description": "TS-001 - basic reachability + GPU/model report.",
          "item": [
            {
              "name": "TS-001: Health Check",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/health",
                  "host": ["{{baseUrl}}"],
                  "path": ["health"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('TS-001: status is 200', () => pm.response.to.have.status(200));",
                      "pm.test('TS-001: response time < 2000 ms', () => pm.expect(pm.response.responseTime).to.be.below(2000));",
                      "const body = pm.response.json();",
                      "pm.test('TS-001: status field is ok', () => pm.expect(body.status).to.eql('ok'));",
                      "pm.test('TS-001: gpu is boolean', () => pm.expect(body.gpu).to.be.a('boolean'));",
                      "pm.test('TS-001: models is array', () => pm.expect(body.models).to.be.an('array'));"
                    ]
                  }
                }
              ]
            }
          ]
        },
