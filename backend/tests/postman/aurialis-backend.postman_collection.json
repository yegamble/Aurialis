              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TS-012 poll: status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.status === 'done') {",
                  "  pm.environment.unset('longPollCount');",
                  "  pm.execution.setNextRequest('TS-012: Long Get Result');",
                  "} else if (body.status === 'error') {",
                  "  pm.test('TS-012: job did not error', () => { throw new Error('Job errored: ' + body.error); });",
                  "  pm.execution.setNextRequest(null);",
                  "} else {",
                  "  const count = parseInt(pm.environment.get('longPollCount') || '0') + 1;",
                  "  pm.environment.set('longPollCount', String(count));",
                  "  const max = parseInt(pm.environment.get('longPollMaxIterations') || '120');",
                  "  if (count >= max) {",
                  "    pm.test('TS-012: poll did not time out', () => { throw new Error('Poll timeout'); });",
                  "    pm.execution.setNextRequest(null);",
                  "  } else {",
                  "    pm.execution.setNextRequest('TS-012: Long Poll Status');",
                  "  }",
                  "}"
                ]
              }
            }
