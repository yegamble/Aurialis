        {
          "name": "TS-012: Long Poll Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/{{longJobId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "{{longJobId}}", "status"]
            }
