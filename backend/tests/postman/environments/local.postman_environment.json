{
  "id": "aurialis-backend-local",
  "name": "Local (docker-compose)",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "default",
      "enabled": true
    },
    {
      "key": "pollIntervalMs",
      "value": "2000",
      "type": "default",
      "enabled": true,
      "description": "Informational — actual delay is set via Newman --delay-request flag."
    },
    {
      "key": "pollMaxIterations",
      "value": "45",
      "type": "default",
      "enabled": true,
      "description": "45 iterations × 2 s delay = 90 s budget for happy-path deep analysis."
    },
    {
      "key": "longPollMaxIterations",
      "value": "120",
      "type": "default",
      "enabled": true,
      "description": "120 iterations × 5 s delay = 600 s budget for nightly 10-minute audio."
    },
    {
      "key": "fixturesDir",
      "value": "./fixtures",
      "type": "default",
      "enabled": true,
      "description": "Relative to --working-dir at runner level."
    }
  ],
  "_postman_variable_scope": "environment"
}
